{
  "name": "eulesia",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "pnpm": {
    "overrides": {
      "qs": "6.14.2"
    }
  },
  "scripts": {
    "dev:web": "pnpm --filter @eulesia/web run dev",
    "build:web": "pnpm --filter @eulesia/web run build",
    "lint": "pnpm run lint:web",
    "lint:web": "pnpm --filter @eulesia/web run lint",
    "lint:web:fix": "pnpm --filter @eulesia/web run lint:fix",
    "check:web": "pnpm --filter @eulesia/web run check",
    "typecheck": "pnpm run typecheck:web",
    "typecheck:web": "pnpm --filter @eulesia/web run typecheck",
    "test": "pnpm run test:web",
    "test:web": "pnpm --filter @eulesia/web run test",
    "test:web:run": "pnpm --filter @eulesia/web run test:run",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2"
  }
}
