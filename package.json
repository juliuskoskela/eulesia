{
  "name": "eulesia-app",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "workspaces": [
    "apps/*"
  ],
  "overrides": {
    "qs": "6.14.2"
  },
  "scripts": {
    "dev": "vite",
    "dev:web": "vite",
    "dev:api": "npm run dev --workspace=@eulesia/api",
    "build": "tsc -b && vite build",
    "build:api": "npm run build --workspace=@eulesia/api",
    "lint": "npm run lint:web && npm run lint:api",
    "lint:web": "eslint src vite.config.ts vitest.config.ts capacitor.config.ts eslint.config.js",
    "lint:api": "npm run lint --workspace=@eulesia/api",
    "check:web": "npm run lint:web && npm run typecheck:web",
    "typecheck": "npm run typecheck:web && npm run typecheck:api",
    "typecheck:web": "tsc -b --pretty false",
    "typecheck:api": "npm run typecheck --workspace=@eulesia/api",
    "preview": "vite preview",
    "test": "npm run test:web && npm run test:api",
    "test:web": "vitest",
    "test:api": "npm run test --workspace=@eulesia/api",
    "test:run": "npm run test:web:run && npm run test:api:run",
    "test:web:run": "vitest run",
    "test:api:run": "npm run test:run --workspace=@eulesia/api",
    "test:coverage": "vitest run --coverage",
    "cap:sync": "npx cap sync",
    "cap:build": "vite build && npx cap sync",
    "cap:open:ios": "npx cap open ios",
    "cap:open:android": "npx cap open android",
    "cap:run:ios": "npx cap run ios",
    "cap:run:android": "npx cap run android"
  },
  "dependencies": {
    "@capacitor/android": "^8.1.0",
    "@capacitor/app": "^8.0.1",
    "@capacitor/cli": "^8.1.0",
    "@capacitor/core": "^8.1.0",
    "@capacitor/ios": "^8.1.0",
    "@capacitor/keyboard": "^8.0.0",
    "@capacitor/push-notifications": "^8.0.1",
    "@capacitor/status-bar": "^8.0.1",
    "@tailwindcss/vite": "^4.1.18",
    "@tanstack/react-query": "^5.90.19",
    "dompurify": "^3.3.1",
    "i18next": "^25.8.4",
    "i18next-browser-languagedetector": "^8.2.0",
    "i18next-http-backend": "^3.0.2",
    "leaflet": "^1.9.4",
    "lucide-react": "^0.562.0",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "react-helmet-async": "^2.0.5",
    "react-i18next": "^16.5.4",
    "react-leaflet": "^5.0.0",
    "react-leaflet-cluster": "^4.0.0",
    "react-router-dom": "^7.12.0",
    "socket.io-client": "^4.8.3",
    "tailwindcss": "^4.1.18",
    "vite-plugin-pwa": "^1.2.0"
  },
  "devDependencies": {
    "@capacitor/assets": "^3.0.5",
    "@eslint/js": "^9.39.1",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/dompurify": "^3.0.5",
    "@types/leaflet": "^1.9.21",
    "@types/node": "^24.10.1",
    "@types/react": "^19.2.5",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.2",
    "eslint": "^9.39.1",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.24",
    "globals": "^16.5.0",
    "jsdom": "^27.4.0",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.46.4",
    "vite": "^7.2.4",
    "vitest": "^4.0.18"
  }
}
