# =============================================================================
# WHITELIST GITIGNORE
# =============================================================================
#
# Pattern: Ignore everything (*), then explicitly allow tracked/project paths.
# =============================================================================

*

# === Directories ===
!android/
!android/**
!apps/
!apps/**
!assets/
!assets/**
!docker/
!docker/**
!docs/
!docs/**
!icons/
!icons/**
!ios/
!ios/**
!nix/
!nix/**
!public/
!public/**
!scripts/
!scripts/**
!src/
!src/**

# === Root Files (anchored with /) ===
!/.gitignore
!/.npmrc
!/.env.production
!/.sops.yaml
!/LICENSE
!/README.md
!/capacitor.config.ts
!/eslint.config.js
!/flake.lock
!/flake.nix
!/index.html
!/package-lock.json
!/package.json
!/tsconfig.app.json
!/tsconfig.json
!/tsconfig.node.json
!/vite.config.ts
!/vitest.config.ts

# === Exclusions (re-ignore in whitelisted dirs) ===
# Local untracked files
local/
result
result-*

# Logs
logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# Build artifacts
node_modules
apps/*/node_modules
dist
dist-ssr
apps/*/dist
*.local

# Environment files
.env
.env.local
.env.*.local
docker/.env

# Editor directories and files
.vscode/*
!.vscode/extensions.json
.idea
.DS_Store
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?

# Database
*.sql.backup

# SSL certificates (local dev)
*.pem
*.key
*.crt

# Firebase config files (contain API keys)
android/app/google-services.json
ios/App/App/GoogleService-Info.plist

# Capacitor native build artifacts
ios/App/Pods/
ios/App/App.xcworkspace/
*.xcuserdata
android/.gradle/
android/app/build/
android/build/
android/capacitor-cordova-android-plugins/build/
*.ipa
*.apk
*.aab
