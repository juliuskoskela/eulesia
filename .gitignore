# =============================================================================
# WHITELIST GITIGNORE
# =============================================================================
#
# Pattern: Ignore everything (*), then explicitly allow tracked/project paths.
# =============================================================================

*

# === Directories ===
!agents/
!agents/**
!apps/
!apps/**
!crates/
!crates/**
!.claude/
!.claude/**
!.codex/
!.codex/**
!.github/
!.github/**
!docs/
!docs/**
!nix/
!nix/**
!secrets/
!secrets/**
!tests/
!tests/**

# === Root Files (anchored with /) ===
!/Cargo.toml
!/Cargo.lock
!/.envrc
!/.gitignore
!/.npmrc
!/.env.production
!/.sops.yaml
!/LICENSE
!/README.md
!/flake.lock
!/flake.nix
!/justfile
!/package.json
!/pnpm-lock.yaml
!/pnpm-workspace.yaml
!/playwright.config.ts

# === Exclusions (re-ignore in whitelisted dirs) ===
# Local untracked files
local/
.artifacts/
result
result-*

# Logs
logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# Build artifacts
target/
node_modules
apps/*/node_modules
dist
dist-ssr
apps/*/dist
*.local

# Environment files
.env
.env.local
.env.*.local
docker/.env
.eulesia/

# Editor directories and files
.vscode/*
!.vscode/extensions.json
.idea
.DS_Store
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?

# Database
*.sql.backup

# SSL certificates (local dev)
*.pem
*.key
*.crt

# Firebase config files (contain API keys)
android/app/google-services.json
ios/App/App/GoogleService-Info.plist

# Capacitor native build artifacts
ios/App/Pods/
ios/App/App.xcworkspace/
*.xcuserdata
android/.gradle/
android/app/build/
android/build/
android/capacitor-cordova-android-plugins/build/
*.ipa
*.apk
*.aab
